# ============================================================
# Autonomous Business Operations Copilot — Environment Config
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# --- Gemini API ---
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL_PLANNER=gemini-2.5-pro
GEMINI_MODEL_DEFAULT=gemini-2.5-flash
GEMINI_MODEL_DRAFT=gemini-2.5-pro

# --- Neo4j ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password-here
NEO4J_DATABASE=neo4j

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=copilot
POSTGRES_PASSWORD=your-postgres-password-here
POSTGRES_DB=copilot_db

# --- SQLite (Dev Fallback) ---
SQLITE_DB_PATH=./data/copilot_dev.db

# --- ChromaDB ---
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION=copilot_documents

# --- FAISS ---
FAISS_INDEX_PATH=./data/faiss_indices

# --- Embeddings ---
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# --- Application ---
APP_NAME=Autonomous Business Ops Copilot
APP_ENV=development
APP_DEBUG=true
APP_LOG_LEVEL=INFO
APP_SECRET_KEY=your-secret-key-change-in-production

# --- API Server ---
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
API_RELOAD=true

# --- Rate Limiting ---
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# --- CORS ---
CORS_ORIGINS=["http://localhost:8501"]
CORS_ALLOW_CREDENTIALS=true

# --- Streamlit ---
STREAMLIT_PORT=8501

# --- Observability ---
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key
LANGFUSE_SECRET_KEY=your-langfuse-secret-key
LANGFUSE_HOST=https://cloud.langfuse.com
ENABLE_TRACING=true

# --- Security ---
JWT_SECRET_KEY=your-jwt-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60
PII_DETECTION_ENABLED=true
PROMPT_INJECTION_DEFENSE_ENABLED=true

# --- Retrieval ---
BM25_TOP_K=25
VECTOR_TOP_K=25
GRAPH_TOP_K=25
RERANKER_TOP_K=5
RRF_K=60

# --- Confidence Engine ---
CONFIDENCE_HIGH_THRESHOLD=85
CONFIDENCE_LOW_THRESHOLD=60

# --- Cost Tracking ---
GEMINI_FLASH_INPUT_COST_PER_1K=0.000075
GEMINI_FLASH_OUTPUT_COST_PER_1K=0.0003
GEMINI_PRO_INPUT_COST_PER_1K=0.00125
GEMINI_PRO_OUTPUT_COST_PER_1K=0.005
